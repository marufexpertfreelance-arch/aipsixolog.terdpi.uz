# OpenServer Configuration
# Этот файл должен быть в папке public/

<IfModule pagespeed_module>
  ModPagespeed off
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Если запрос идет к существующему файлу или директории, не перенаправляем
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Перенаправляем все запросы в index.php
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Запрещаем доступ к скрытым файлам
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Устанавливаем правильную кодировку
AddDefaultCharset UTF-8

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php81” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php81___lsphp .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
